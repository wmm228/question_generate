{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "edu-question-spec.schema.json",
  "title": "edu-question-spec.v1",
  "type": "object",
  "required": ["subject", "question_type", "difficulty"],
  "anyOf": [
    { "required": ["knowledge_points"] },
    { "required": ["knowledge_point"] }
  ],
  "$defs": {
    "evoqConfig": {
      "type": "object",
      "description": "EvoQ GA configuration. Compatible with the original EvoQ ga.* config and OAH/API evoq_config aliases.",
      "properties": {
        "pop_size": { "type": "integer", "minimum": 2, "maximum": 20 },
        "population_size": { "type": "integer", "minimum": 2, "maximum": 20 },
        "generations": { "type": "integer", "minimum": 0, "maximum": 10 },
        "mutation_rounds": { "type": "integer", "minimum": 0, "maximum": 10 },
        "elite_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "lambda_ratio": { "type": "number", "minimum": 0, "maximum": 5 },
        "selection_strategy": { "enum": ["tournament", "roulette", "random"] },
        "tournament_k": { "type": "integer", "minimum": 1, "maximum": 20 },
        "init_strategy": { "enum": ["auto", "dataset", "mixed"] },
        "fitness_diff_metric": {
          "enum": ["irt_strict", "irt_soft", "rankllm_strict", "rankllm_soft"]
        },
        "early_stop_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "early_stop_requires_no_issues": { "type": "boolean" },
        "min_generations_before_early_stop": { "type": "integer", "minimum": 0, "maximum": 10 },
        "max_attempt_multiplier": { "type": "integer", "minimum": 1, "maximum": 10 },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "seed_strategies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "properties": {
    "version": { "const": "edu-question-spec.v1" },
    "request_id": { "type": "string" },
    "locale": { "type": "string", "default": "zh-CN" },
    "grade_band": { "type": "string" },
    "subject": { "type": "string", "minLength": 1 },
    "knowledge_points": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "knowledge_point": { "type": "string", "minLength": 1 },
    "curriculum_goal": { "type": "string" },
    "question_type": {
      "enum": ["single_choice", "multiple_choice", "true_false", "fill_blank", "short_answer"]
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 1
    },
    "content_mode": {
      "enum": ["text", "image", "diagram_optional", "diagram_required"],
      "default": "text"
    },
    "image_requirement": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "image_required": { "type": "boolean" },
            "position": { "enum": ["stem", "options", "explanation"] },
            "image_position": { "enum": ["stem", "options", "explanation"] },
            "answer_relevant": { "type": "boolean" },
            "must_be_answer_relevant": { "type": "boolean" }
          }
        }
      ]
    },
    "diagram": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "position": { "enum": ["stem", "options", "explanation"] },
        "must_be_answer_relevant": { "type": "boolean" },
        "style": { "type": "string" }
      }
    },
    "strategy": {
      "enum": ["direct", "cot", "react", "dear", "eqpr", "evoq"],
      "default": "direct"
    },
    "algorithm": {
      "enum": ["direct", "cot", "react", "dear", "eqpr", "evoq"],
      "default": "direct"
    },
    "evoq_config": { "$ref": "#/$defs/evoqConfig" },
    "evoq": { "$ref": "#/$defs/evoqConfig" },
    "ga": { "$ref": "#/$defs/evoqConfig" },
    "teacher_profile": { "type": "object" },
    "student_profile": {
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "level": { "type": "string" },
        "ability_theta": { "type": "number", "minimum": -4, "maximum": 4 },
        "theta": { "type": "number", "minimum": -4, "maximum": 4 },
        "common_errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "misconceptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mastery": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["knowledge_point", "mastery"],
            "properties": {
              "knowledge_point": { "type": "string" },
              "mastery": { "type": "number", "minimum": 0, "maximum": 1 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "evidence": { "type": "string" }
            }
          }
        },
        "irt": {
          "type": "object",
          "properties": {
            "theta": { "type": "number", "minimum": -4, "maximum": 4 },
            "ability_theta": { "type": "number", "minimum": -4, "maximum": 4 },
            "difficulty_b": { "type": "number", "minimum": -4, "maximum": 4 },
            "b": { "type": "number", "minimum": -4, "maximum": 4 }
          }
        }
      }
    },
    "source_material": { "type": "string" },
    "extra_requirements": { "type": "string" }
  }
}
