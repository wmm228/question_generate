{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@oah/config": ["./packages/config/src/index.ts"],
      "@oah/config/*": ["./packages/config/src/*"],
      "@oah/api-contracts": ["./packages/api-contracts/src/index.ts"],
      "@oah/engine-core": ["./packages/engine-core/src/index.ts"],
      "@oah/engine-core/types": ["./packages/engine-core/src/types.ts"],
      "@oah/engine-core/engine/engine-messages": ["./packages/engine-core/src/engine/engine-messages.ts"],
      "@oah/storage-memory": ["./packages/storage-memory/src/index.ts"],
      "@oah/storage-sqlite": ["./packages/storage-sqlite/src/index.ts"],
      "@oah/storage-postgres": ["./packages/storage-postgres/src/index.ts"],
      "@oah/storage-redis": ["./packages/storage-redis/src/index.ts"],
      "@oah/config-server-control": ["./packages/config-server-control/src/index.ts"],
      "@oah/scale-target-control": ["./packages/scale-target-control/src/index.ts"],
      "@oah/storage-redis-control": ["./packages/storage-redis-control/src/index.ts"],
      "@oah/model-runtime": ["./packages/model-runtime/src/index.ts"],
      "@oah/model-runtime/providers": ["./packages/model-runtime/src/providers.ts"],
      "@oah/native-bridge": ["./packages/native-bridge/src/index.ts"]
    }
  }
}
