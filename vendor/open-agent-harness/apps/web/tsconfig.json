{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@oah/config": ["../../packages/config/src/index.ts"],
      "@oah/api-contracts": ["../../packages/api-contracts/src/index.ts"],
      "@oah/engine-core": ["../../packages/engine-core/src/index.ts"],
      "@oah/storage-memory": ["../../packages/storage-memory/src/index.ts"],
      "@oah/storage-sqlite": ["../../packages/storage-sqlite/src/index.ts"],
      "@oah/storage-postgres": ["../../packages/storage-postgres/src/index.ts"],
      "@oah/storage-redis": ["../../packages/storage-redis/src/index.ts"],
      "@oah/model-runtime": ["../../packages/model-runtime/src/index.ts"],
      "@oah/model-runtime/providers": ["../../packages/model-runtime/src/providers.ts"]
    },
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
