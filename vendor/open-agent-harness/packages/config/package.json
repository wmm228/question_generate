{
  "name": "@oah/config",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./platform-models": {
      "types": "./src/platform-models.ts",
      "default": "./dist/platform-models.js"
    },
    "./object-storage": {
      "types": "./src/object-storage.ts",
      "default": "./dist/object-storage.js"
    },
    "./runtimes": {
      "types": "./src/runtimes.ts",
      "default": "./dist/runtimes.js"
    },
    "./server-config": {
      "types": "./src/server-config.ts",
      "default": "./dist/server-config.js"
    },
    "./workspace": {
      "types": "./src/workspace.ts",
      "default": "./dist/workspace.js"
    }
  },
  "dependencies": {
    "@oah/api-contracts": "workspace:*",
    "@oah/native-bridge": "workspace:*",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "gray-matter": "4.0.3",
    "yauzl": "^3.2.0",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@types/yauzl": "^2.10.3"
  }
}
