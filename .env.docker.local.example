# Copy to .env.docker.local and fill deployment-specific secrets.
POSTGRES_PASSWORD=replace-with-a-random-password

# Required when TUTOR_AUTH_PROVIDER=zitadel.
ZITADEL_BASE_URL=https://zitadel.example.com
ZITADEL_CLIENT_ID=replace-with-zitadel-client-id
ZITADEL_PAT=replace-with-zitadel-pat

# Only for trusted local/lab HTTP auth endpoints.
ZITADEL_ALLOW_INSECURE_HTTP=false

# Only needed when enabling the cloudflare compose profile.
CLOUDFLARED_DIR=C:/Users/HP/.cloudflared
CLOUDFLARED_TUNNEL_ID=replace-with-tunnel-id
