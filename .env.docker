TUTOR_PORT=7896
TUTOR_STORAGE_BACKEND=postgres
TUTOR_AUTH_BYPASS=false
TUTOR_AUTH_BYPASS_UID=admin
TUTOR_AUTH_PROVIDER=zitadel
ZITADEL_BASE_URL=
ZITADEL_CLIENT_ID=
ZITADEL_REQUEST_TIMEOUT_MS=10000
# Put ZITADEL_PAT or ZITADEL_PERSONAL_ACCESS_TOKEN in .env.docker.local.
# HTTP ZITADEL URLs are rejected unless ZITADEL_ALLOW_INSECURE_HTTP=true is set.

OAH_BASE_URL=http://oah:8787
OAH_AGENT_NAME=question-orchestrator
OAH_INTENT_AGENT_NAME=intent-recognizer
OAH_INTENT_MODEL_NAME=
OAH_WORKSPACE_RUNTIME=tutor-question-generation
OAH_WORKSPACE_NAME=tutor-question-generation
OAH_WORKSPACE_OWNER_ID=tutor
OAH_WORKSPACE_SERVICE_NAME=
OAH_WORKSPACE_AUTO_CREATE=true
OAH_RUN_POLL_INTERVAL_MS=1000
OAH_RUN_TIMEOUT_MS=1800000
OAH_REQUEST_TIMEOUT_MS=240000
OAH_PORTRAIT_DIALOGUE_TIMEOUT_MS=600000
OAH_MODEL_NAME=platform/qwen_qwen3-next-80b-a3b-instruct
OAH_MODEL_PRIORITY=platform/qwen_qwen3-next-80b-a3b-instruct,platform/minimaxai_minimax-m2.7,platform/stepfun-ai_step-3.5-flash,platform/openai_gpt-oss-20b,platform/nvidia_nemotron-3-nano-30b-a3b,platform/meta_llama-3.3-70b-instruct,platform/mistralai_ministral-14b-instruct-2512,platform/google_gemma-4-31b-it,platform/qwen_qwen3.5-122b-a10b,platform/qwen_qwen3.5-397b-a17b,platform/kimi-k26,platform/GLM-5.1-FP8,platform/kimi-k25
OAH_MODEL_RETRY_ATTEMPTS=0
OAH_ALLOW_5173_FALLBACK=false
OAH_MODEL_FALLBACK_ENABLED=true

CLOUDFLARED_DIR=
CLOUDFLARED_TUNNEL_ID=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tutor
POSTGRES_USER=tutor
# Required in .env.docker.local:
# POSTGRES_PASSWORD=replace-with-a-random-password
